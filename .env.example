# eBird API key — free at https://ebird.org/api/keygen
EBIRD_API_KEY=

# xeno-canto v3 API key — free at https://xeno-canto.org (account settings)
XC_API_KEY=

# Public port nginx binds on the host. Defaults to 32095 (dev/testbed).
# Cut over to 32085 to replace the old birding app on bird.folkengames.com.
WEB_PORT=32095
